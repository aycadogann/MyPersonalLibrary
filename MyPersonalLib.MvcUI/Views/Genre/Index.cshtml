@model IEnumerable<MyPersonalLib.MvcUI.Models.GenreListViewModel>
@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>
<hr />

<table class="table table-bordered table-hover table-striped">
    <tr>
        <th> ID</th>
        <th> Kitap Türü</th>
        <th> </th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ID</td>
            <td>@item.BookGenre</td>
            <td></td>
        </tr>
    }
</table>

