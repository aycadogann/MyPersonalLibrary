@model  IEnumerable<MyPersonalLib.MvcUI.Models.BookListViewModel>
@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<table class="table table-bordered table-hover table-striped">
    <tr>
        <th> Kitap Adı</th>
        <th> Yazar</th>
        <th> Durum</th>
        <th> Puan</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.BookName</td>
            <td>@item.Author</td>
            <td>@item.Status</td>
            <td>@item.Rate</td>
        </tr>
    }


</table>

